<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Grocery Tracker</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="app">
      <section class="card">
        <h1>Grocery Tracker</h1>
        <p class="subtitle">Keep track of what you need to buy.</p>

        <form id="add-item-form" class="item-form">
          <input type="text" name="name" placeholder="Milk, eggs, bread..." required />
          <input type="number" name="quantity" min="1" value="1" />
          <button type="submit">Add Item</button>
        </form>

        <% if (error) { %>
        <p class="error"><%= error %></p>
        <% } %>

        <ul class="item-list">
          <% items.forEach((item) => { %>
          <li class="item-card <%= item.purchased ? 'purchased' : '' %>">
            <div>
              <h3><%= item.name %></h3>
              <p>Qty: <%= item.quantity %></p>
            </div>
            <div class="actions">
              <button class="toggle-btn" data-id="<%= item._id %>">
                <%= item.purchased ? 'Undo' : 'Bought' %>
              </button>
              <button class="delete-btn" data-id="<%= item._id %>">Delete</button>
            </div>
          </li>
          <% }) %>
        </ul>
      </section>
    </main>

    <script src="/js/app.js"></script>
  </body>
</html>
